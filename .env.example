# GaggiMate Bridge — environment template
# Copy to .env and fill in your values. Never commit .env.
#
# GaggiMate connection
GAGGIMATE_HOST=192.168.1.100
GAGGIMATE_PROTOCOL=ws
REQUEST_TIMEOUT=5000

# API authentication (required — used by Barista agent)
API_TOKEN=your-secret-token-here

# Sync settings
SYNC_INTERVAL_MS=30000

# Shot cache retention (days)
SHOT_RETENTION_DAYS=7

# Connectivity cooldown after device goes offline (ms, default 3 minutes)
CONNECTIVITY_COOLDOWN_MS=180000

# HTTP server
HTTP_PORT=3000

# Data directory (for sync state + shot cache persistence)
DATA_DIR=./data
